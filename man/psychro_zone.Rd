\item \code{"specvol-rh"} or \code{"volume-rh"}: \code{specvol_min}, \code{specvol_max},
\code{relhum_min}, and \code{relhum_max}
\item \code{"dbt-wmax"}: \code{tdb_min}, \code{tdb_max}, \code{humratio_max}, and optional
